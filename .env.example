# ─────────────────────────────────────────────
#  WhatsApp Business Cloud API
# ─────────────────────────────────────────────
# Found in: Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxx
# A random string YOU choose — must match what you enter in Meta's webhook config
WHATSAPP_VERIFY_TOKEN=my_secret_verify_token_123

# ─────────────────────────────────────────────
#  Business Configuration
# ─────────────────────────────────────────────
# Type of business: salon | restaurant | spaza
BUSINESS_TYPE=salon
BUSINESS_NAME=Glamour Salon
# Optional: override the welcome message (falls back to DB value)
# WELCOME_MESSAGE=

# ─────────────────────────────────────────────
#  Server
# ─────────────────────────────────────────────
PORT=3000
# The public URL of your server (needed for Meta webhook registration)
WEBHOOK_URL=https://your-domain.com/webhook

# ─────────────────────────────────────────────
#  Dashboard (optional basic auth)
# ─────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme

# ─────────────────────────────────────────────
#  Database (SQLite default — swap for Postgres)
# ─────────────────────────────────────────────
# Leave blank for SQLite. Set for Postgres:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
